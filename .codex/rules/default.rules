# Codex CLI command execution rules (Starlark format)
# Mirrors the broad command-family permissions in .claude/settings.json.example.

# Git and GitHub CLI
prefix_rule(pattern=["git"], decision="allow")
prefix_rule(pattern=["gh"], decision="allow")

# Build tools and shells
prefix_rule(pattern=["bash"], decision="allow")
prefix_rule(pattern=["make"], decision="allow")

# Scripting languages
prefix_rule(pattern=["Rscript"], decision="allow")
prefix_rule(pattern=["julia"], decision="allow")
prefix_rule(pattern=["python3"], decision="allow")
prefix_rule(pattern=["stata"], decision="allow")
prefix_rule(pattern=["stata-mp"], decision="allow")
prefix_rule(pattern=["matlab"], decision="allow")

# Common inspection and text-processing utilities
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["sed"], decision="allow")
prefix_rule(pattern=["head"], decision="allow")
prefix_rule(pattern=["tail"], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["sort"], decision="allow")
prefix_rule(pattern=["grep"], decision="allow")
prefix_rule(pattern=["awk"], decision="allow")
prefix_rule(pattern=["jq"], decision="allow")

# File utilities
prefix_rule(pattern=["chmod"], decision="allow")
prefix_rule(pattern=["cp"], decision="allow")
prefix_rule(pattern=["mv"], decision="allow")
prefix_rule(pattern=["open"], decision="allow")
prefix_rule(pattern=["mkdir"], decision="allow")

# LaTeX and PDF toolchain
prefix_rule(pattern=["pdflatex"], decision="allow")
prefix_rule(pattern=["xelatex"], decision="allow")
prefix_rule(pattern=["latexmk"], decision="allow")
prefix_rule(pattern=["bibtex"], decision="allow")
prefix_rule(pattern=["pdfinfo"], decision="allow")
prefix_rule(pattern=["pdf2svg"], decision="allow")
prefix_rule(pattern=["gs"], decision="allow")
prefix_rule(pattern=["pdftk"], decision="allow")
