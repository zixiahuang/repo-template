# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
/settings.json
*.swp
*.swo
*~

# AI coding assistants — local state
**/.claude/settings.local.json
.claude/settings.json
.claude/state/
# Codex CLI -- track config and rules, ignore local state
.codex/*
!.codex/config.toml
!.codex/rules
.codex/rules/*
!.codex/rules/default.rules
.gemini/

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf
latex/manuscript.pdf
latex/slides.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R / RStudio
.Rproj.user/
.Rhistory
.Rapp.history
.RData
.Rdata
.httr-oauth
renv/library*
rsconnect/

# R package build artifacts
*-Ex.R
/*.tar.gz
/*.Rcheck/
vignettes/*.html
vignettes/*.pdf

# R Markdown / knitr
/*_cache/
/cache/
*.utf8.md
*.knit.md

# MATLAB
*.asv
*.mat

# Julia
Manifest.toml

# Environment / secrets
.env*

# Data / Output — ignore contents but keep directory structure
data/*
!data/.gitkeep
output/
